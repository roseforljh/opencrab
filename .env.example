# 这个文件用于展示 OpenCrab 当前最小 Chat Completions 代理后端支持的环境变量。

# HTTP 服务监听地址，默认 :8080。
OPENCRAB_HTTP_ADDR=:8080

# 当前网关 provider。现在只支持 openai。
OPENCRAB_GATEWAY_PROVIDER=openai

# 上游 OpenAI API 地址，默认 https://api.openai.com。
OPENCRAB_UPSTREAM_BASE_URL=https://api.openai.com

# 上游 OpenAI API Key。未设置时，会尝试透传来访请求里的 Authorization。
OPENCRAB_UPSTREAM_API_KEY=

# 上游请求超时，默认 120s。
OPENCRAB_UPSTREAM_TIMEOUT=120s

# Claude 原生接口上游地址，默认 https://api.anthropic.com。
OPENCRAB_ANTHROPIC_BASE_URL=https://api.anthropic.com

# Claude 原生接口上游 API Key。
OPENCRAB_ANTHROPIC_API_KEY=

# Claude 原生接口版本头，默认 2023-06-01。
OPENCRAB_ANTHROPIC_VERSION=2023-06-01
