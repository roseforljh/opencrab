# 这个文件用于展示 OpenCrab 后端当前支持的最基础环境变量。
#
# 当前阶段只开放最少的启动配置，方便本地开发和 Docker 部署先跑起来。

# 应用名称，会用于启动日志和后续健康检查输出。
OPENCRAB_APP_NAME=OpenCrab

# 当前运行环境，默认 development。
OPENCRAB_ENV=development

# HTTP 服务监听地址，默认 :8080。
OPENCRAB_HTTP_ADDR=:8080

# SQLite 数据库文件路径，默认放在 data/opencrab.db。
OPENCRAB_DB_PATH=./data/opencrab.db
